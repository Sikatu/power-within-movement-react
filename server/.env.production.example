# Backend production example
# Do not commit real secrets.

NODE_ENV=production
PORT=8787

# Use every frontend origin that should be allowed to call this backend.
CLIENT_ORIGINS=https://www.kimmittlestadt.com,https://kimmittlestadt.com

PUBLIC_SITE_URL=https://www.kimmittlestadt.com

DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Generate a long random secret before production.
JWT_SECRET=replace-with-a-long-random-production-secret

# For separate frontend/backend domains, SameSite=None + Secure is usually required.
COOKIE_SECURE=true
COOKIE_SAMESITE=none

# Optional. Only use when backend and frontend share a controllable root domain.
# COOKIE_DOMAIN=.kimmittlestadt.com

# Email provider delivery adapter.
RESEND_API_KEY=replace-with-live-resend-key
PORTAL_EMAIL_FROM=Power Within Collective <hello@kimmittlestadt.com>

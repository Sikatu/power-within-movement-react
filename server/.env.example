PORT=8787
NODE_ENV=development
CLIENT_ORIGINS=http://localhost:5173,http://localhost:5174

# Local PostgreSQL example:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/power_within_native

DATABASE_URL=

# Change this before real production deployment.
JWT_SECRET=change-this-dev-secret-before-production

# First owner seed values.
# These are used only when running: npm run db:seed-owner
SEED_OWNER_EMAIL=
SEED_OWNER_PASSWORD=
SEED_OWNER_FIRST_NAME=
SEED_OWNER_LAST_NAME=

# Letters & Broadcasts delivery. Keep real provider keys out of source control.
PUBLIC_SITE_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:8787
RESEND_API_KEY=
NEWSLETTER_EMAIL_FROM=
NEWSLETTER_REPLY_TO=
RESEND_WEBHOOK_SECRET=
LETTER_SIGNING_SECRET=
LETTER_SEND_CONCURRENCY=1
LETTER_SEND_BATCH_DELAY_MS=550

# Asset Vault storage. Local is private filesystem storage for development.
ASSET_STORAGE_DRIVER=local
ASSET_STORAGE_DIR=
ASSET_MAX_UPLOAD_BYTES=52428800
ASSET_ACCESS_GRANT_SECRET=
ASSET_ACCESS_GRANT_TTL_SECONDS=300

# Phase 26R.2 scanner adapter. Keep disabled until a production scanner adapter is connected.
ASSET_MALWARE_SCANNER=disabled

# S3-compatible production storage. Required when ASSET_STORAGE_DRIVER=s3.
ASSET_S3_ENDPOINT=
ASSET_S3_REGION=us-east-1
ASSET_S3_BUCKET=
ASSET_S3_ACCESS_KEY_ID=
ASSET_S3_SECRET_ACCESS_KEY=
ASSET_S3_FORCE_PATH_STYLE=true

# Founder Command Center transcription stays disabled until a server-side
# provider endpoint and credential are intentionally configured. Never expose
# this API key through Vite or browser environment variables.
FOUNDER_TRANSCRIPTION_PROVIDER=disabled
FOUNDER_TRANSCRIPTION_API_URL=
FOUNDER_TRANSCRIPTION_API_KEY=
FOUNDER_TRANSCRIPTION_MODEL=
FOUNDER_TRANSCRIPTION_TIMEOUT_MS=120000

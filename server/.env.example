PORT=8787
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Local PostgreSQL example:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/power_within_native

DATABASE_URL=

# Change this before real production deployment.
JWT_SECRET=change-this-dev-secret-before-production

# First owner seed values.
# These are used only when running: npm run db:seed-owner
SEED_OWNER_EMAIL=
SEED_OWNER_PASSWORD=
SEED_OWNER_FIRST_NAME=
SEED_OWNER_LAST_NAME=
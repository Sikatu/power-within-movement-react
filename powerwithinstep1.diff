+  --pw-footer-eyebrow: #c8a96a;
+
+  --pw-hairline: rgba(124, 81, 75, 0.12);
+  --pw-hairline-strong: rgba(124, 81, 75, 0.16);
+
+  --pw-success-text: #5b8c6e;
+  --pw-success-bg: rgba(91, 140, 110, 0.13);
